{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "src/**",
      "use": "@vercel/static"
    },
    {
      "src": "docs/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/docs/analise-violencia",
      "destination": "/docs/analise-violencia.html"
    },
    {
      "source": "/docs/metodologia",
      "destination": "/docs/metodologia.html"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
