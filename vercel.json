{
  "version": 2,
  "name": "forensenet-analytics",
  "builds": [
    { "src": "api/collect.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/collect", "dest": "api/collect.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/collect",
      "schedule": "0 8,20 * * *"
    }
  ]
}
