{
  "version": 2,
  "name": "projeto-odio-politica",
  "cleanUrls": true,
  "framework": null,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/engine_backend.py", "use": "@vercel/python" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/engine_backend.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
