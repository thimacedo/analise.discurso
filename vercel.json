{
  "version": 2,
  "rewrites": [
    { "source": "/api/collect", "destination": "api/collect.py" },
    { "source": "/api/(.*)", "destination": "api/collect.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/collect",
      "schedule": "0 8,20 * * *"
    }
  ]
}
