{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/admin", "destination": "/addalvo.html" },
    { "source": "/docs/metodologia", "destination": "/docs/metodologia.html" },
    { "source": "/docs/analise-violencia", "destination": "/docs/analise-violencia.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
