{
  "version": 2,
  "name": "projeto-odio-politica",
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "api/collect.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
