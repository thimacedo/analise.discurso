# .python-version

# pipenv
#   According to pypa/pipenv#1191, it is recommended to not check in Pipfile.lock into libraries.
#   For apps, you should check it in.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   pypa/poetry#1634
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#   pdm-project/pdm#1235
.pdm-python
.pdm-build/

