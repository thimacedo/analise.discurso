{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🛡️ Sentinela: Backend (FastAPI)",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "api.index:app",
                "--host", "0.0.0.0",
                "--port", "8000",
                "--reload"
            ],
            "jinja": true,
            "justMyCode": true,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "🧠 Sentinela: Gemini ↔ Gemma Bridge",
            "type": "python",
            "request": "launch",
            "program": "E:/Projetos/gemini_gemma_bridge.py",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "🔍 Debug: Script Atual",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "🌐 View Dashboard (Local)",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}"
        }
    ]
}