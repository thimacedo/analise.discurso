            batch = comentarios[i:i+50]
            httpx.post(f"{SUPABASE_URL}/rest/v1/comentarios", json=batch, headers=HEADERS)
        print(f"   ✅ Sincronização concluída.")

def main():
    if not os.path.exists("data/priority_queue.json"):
