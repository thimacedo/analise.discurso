name: ForenseNet Daily Pipeline

on:
  schedule:
    - cron: '0 9,21 * * *' # 09:00 e 21:00 UTC
  workflow_dispatch: # Permite disparo manual pelo painel do GitHub

jobs:
  run-pipeline:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'

      - name: Install Dependencies
        run: |
          pip install instagrapi pandas python-dotenv httpx apify-client

      - name: Run Monitoring Sync
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_KEY: ${{ secrets.SUPABASE_KEY }}
          APIFY_API_TOKEN: ${{ secrets.APIFY_API_TOKEN }}
          IG_USERNAME: ${{ secrets.IG_USERNAME }}
          IG_PASSWORD: ${{ secrets.IG_PASSWORD }}
          INVESTIGATOR_ID: ${{ secrets.INVESTIGATOR_ID }}
        run: python sync_intelligence.py

      - name: Run Full Scraper (Apify)
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_KEY: ${{ secrets.SUPABASE_KEY }}
          APIFY_API_TOKEN: ${{ secrets.APIFY_API_TOKEN }}
        run: python full_apify_scraper.py

      - name: Run AI Classification
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_KEY: ${{ secrets.SUPABASE_KEY }}
        run: python cloud_classifier.py
